1664:CMSIS/Include/core_cm4.h ****   reg_value  =  (reg_value                                   |
1665:CMSIS/Include/core_cm4.h ****                 ((uint32_t)0x5FAUL << SCB_AIRCR_VECTKEY_Pos) |
